# Required
NEXTAUTH_SECRET=                        # openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
GITHUB_CLIENT_ID=                       # from GitHub OAuth App
GITHUB_CLIENT_SECRET=                   # from GitHub OAuth App
ANTHROPIC_API_KEY=                      # from console.anthropic.com

# Optional — AI provider override
ANTHROPIC_BASE_URL=                     # e.g. https://openrouter.ai/api/v1
AI_MODEL=claude-sonnet-4-6              # any model ID supported by your provider

# Optional — Jira integration
JIRA_BASE_URL=                          # e.g. https://yourorg.atlassian.net
JIRA_TOKEN=                             # Jira API token

# Optional — GitHub Gist export
GITHUB_TOKEN=                           # GitHub PAT with gist scope

# Optional — headless CLI endpoint protection (only needed if exposing the server publicly)
CLI_SECRET=                             # any random string; omit for local-only use
